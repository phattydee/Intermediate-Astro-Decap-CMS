<!-- ============================================ --><!--                    Hero                      --><!-- ============================================ -->
<section id="hero-2335">
    <div class="cs-wrapper">
        <div class="cs-container">
            <div class="cs-content">
                <h1 class="cs-title">
                    <span class="cs-tag">We're Building</span> For Better Futures
                </h1>
                <p class="cs-text">
                    We are committed to building a future where innovation,
                    sustainability, and inclusivity come together.
                </p>
                <a href="" class="cs-button-solid"> Get Started Today </a>
                <div class="cs-overlay">
                    <img
                        class="cs-graphic"
                        aria-hidden="true"
                        decoding="async"
                        src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/MISC/slashes.svg"
                        alt="stripes graphic"
                        width="1290"
                        height="684"
                    />
                </div>
            </div>
            <!--To make your own background crops of people use https://www.remove.bg/-->
            <picture class="cs-picture">
                <source
                    media="(max-width: 600px)"
                    srcset="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/People/construction-man2.png"
                />
                <source
                    media="(min-width: 601px)"
                    srcset="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/People/construction-man2.png"
                />
                <img
                    aria-hidden="true"
                    decoding="async"
                    src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/People/construction-man2.png"
                    alt="construction worker"
                    width="581"
                    height="662"
                />
            </picture>
        </div>
        <picture class="cs-background">
            <source
                media="(max-width: 600px)"
                srcset="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/MISC/city-bg2.jpg"
            />
            <source
                media="(min-width: 601px)"
                srcset="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/MISC/city-bg2.jpg"
            />
            <img
                aria-hidden="true"
                decoding="async"
                src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/MISC/city-bg2.jpg"
                alt="construction site"
                width="1290"
                height="684"
            />
        </picture>
    </div>
    <section id="logos-2335">
        <div class="cs-logo-container">
            <div class="cs-logo-content">
                <h2 class="cs-title cs-logo-title">Our Trusted Partners</h2>
            </div>
            <div class="cs-logo-wrapper">
                <img
                    class="cs-logo"
                    src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Logos/construction-logo.svg"
                    alt="logo"
                    width="149"
                    height="40"
                    loading="lazy"
                    decoding="async"
                />
                <img
                    class="cs-logo"
                    src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Logos/construction-logo.svg"
                    alt="logo"
                    width="87"
                    height="49"
                    loading="lazy"
                    decoding="async"
                />
                <img
                    class="cs-logo"
                    src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Logos/construction-logo.svg"
                    alt="logo"
                    width="119"
                    height="43"
                    loading="lazy"
                    decoding="async"
                />
                <img
                    class="cs-logo"
                    src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Logos/construction-logo.svg"
                    alt="logo"
                    width="107"
                    height="49"
                    loading="lazy"
                    decoding="async"
                />
            </div>
        </div>
    </section>
</section>

<style lang="less">
    /*-- -------------------------- -->
<---           Hero             -->
<--- -------------------------- -*/

    /* Mobile - 360px */
    @media only screen and (min-width: 0rem) {
        #hero-2335 {
            overflow: hidden;
            position: relative;
            z-index: 1;

            .cs-wrapper {
                width: 100%;
                padding: clamp(9rem, 23.95vw, 16.125rem) (16/16rem) (0/16rem);
                position: relative;
                z-index: 1;
            }

            .cs-container {
                width: 100%;
                max-width: (1280/16rem);
                margin: auto;
                position: relative;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                gap: (88/16rem);
            }

            .cs-content {
                text-align: left;
                width: 100%;
                max-width: (630/16rem);
                padding: clamp(3.75rem, 8vw, 5rem) clamp(1rem, 5vw, 2rem);
                display: flex;
                flex-direction: column;
                align-items: flex-start;
                position: relative;
                z-index: 1;
            }

            .cs-overlay {
                width: 100%;
                height: 100%;
                background-color: #111418;
                overflow: hidden;
                position: absolute;
                top: 0;
                left: 0;
                z-index: -1;
            }

            .cs-graphic {
                width: (1885/16rem);
                height: auto;
                opacity: 0.1;
                position: absolute;
                bottom: 0;
                right: 0;
            }

            .cs-title {
                font-size: clamp(2.4375rem, 6.4vw, 3.8125rem);
                font-weight: 900;
                text-transform: uppercase;
                line-height: 1.2em;
                width: 100%;
                max-width: 17ch;
                margin: 0 0 (16/16rem);
                color: var(--bodyTextColorWhite);
                position: relative;
            }

            .cs-tag {
                font-size: clamp(1.5625rem, 4vw, 2.4375rem);
                margin-bottom: (4/16rem);
                display: block;
            }

            .cs-text {
                font-size: clamp(1rem, 2.5vw, 1.25rem);
                line-height: 1.5em;
                width: 100%;
                max-width: (580/16rem);
                margin: 0 0 clamp(1.75rem, 4vw, 2.5rem);
                color: var(--bodyTextColorWhite);
                opacity: 0.8;
            }

            .cs-button-solid {
                font-size: (16/16rem);
                text-align: center;
                line-height: clamp(2.875rem, 5.5vw, 3.5rem);
                text-decoration: none;
                font-weight: 700;
                overflow: hidden;
                margin: 0;
                color: #fff;
                padding: 0 (28/16rem);
                background-color: var(--primary);
                display: inline-flex;
                align-items: center;
                justify-content: space-between;
                gap: (12/16rem);
                position: relative;
                z-index: 1;
                transition: color 0.3s;

                &:before {
                    content: "";
                    position: absolute;
                    display: block;
                    height: 100%;
                    width: 0%;
                    background: #000;
                    opacity: 1;
                    top: 0;
                    left: 0;
                    z-index: -1;
                    transition: width 0.3s;
                }

                &:hover {
                    color: #fff;
                    &:before {
                        width: 100%;
                    }
                }
            }

            .cs-picture {
                width: 100%;
                max-width: clamp(26.6875rem, 60vw, 42.5rem);
                height: auto;
                display: flex;
                align-items: flex-end;
                position: relative;
                z-index: 7;

                img {
                    width: 100%;
                    height: auto;
                }
            }

            .cs-background {
                width: 100%;
                height: 100%;
                position: absolute;
                top: 0;
                left: 0;
                z-index: -1;

                img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                    position: absolute;
                    top: 0;
                    left: 0;
                    z-index: -1;
                }
            }
        }
    }

    /* Tablet - 768px */
    @media only screen and (min-width: 48rem) {
        #hero-2335 {
            --paddingBottom: clamp(5rem, 10vw, 7rem);
            padding: clamp(9rem, 23.95vw, 16.125rem) (16/16rem) (0/16rem);
            padding-bottom: var(--paddingBottom);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: (90/16rem);

            .cs-wrapper {
                display: contents;
            }

            .cs-container {
                justify-content: flex-start;
                flex-direction: row;
            }

            .cs-content {
                text-align: left;
                width: 100%;
                max-width: 100%;
                padding: (80/16rem) (32/16rem);
                box-sizing: border-box;
                align-items: flex-start;
            }

            .cs-overlay {
                width: 100vw;
                border-radius: 0 (300/16rem) (300/16rem) 0;
                left: auto;
                right: 0;
            }

            .cs-title {
                width: 55%;
            }

            .cs-text {
                width: 50%;
            }

            .cs-picture {
                width: 56%;
                position: absolute;
                bottom: calc(var(--paddingBottom) * -1 - 3rem);
                right: (-10/16rem);
            }

            .cs-background {
                height: auto;
                bottom: clamp(220px, 15vw, 270px);
            }
        }
    }

    /* Desktop - 1024px */
    @media only screen and (min-width: 64rem) {
        #hero-2335 {
            padding-left: (32/16rem);
            .cs-content {
                width: 80%;
                max-width: (1000/16rem);
                padding-left: 0;
            }

            .cs-graphic {
                width: (2982/16rem);
            }

            .cs-picture {
                width: 50vw;
                right: (16/16rem);
            }
        }
    }

    /*-- -------------------------- -->
<---           Logos            -->
<--- -------------------------- -*/

    /* Mobile - 360px */
    @media only screen and (min-width: 0rem) {
        #logos-2335 {
            padding: 0 (16/16rem);

            .cs-logo-container {
                text-align: center;
                width: 100%;
                max-width: (1280/16rem);
                padding: clamp(3.75rem, 8vw, 5rem) clamp(1rem, 5vw, 6.75rem);
                box-sizing: border-box;
                margin: auto;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                gap: clamp(1rem, 4vw, 4rem);
                position: relative;
                z-index: 1;

                &:before {
                    content: "";
                    width: 100%;
                    height: 100%;
                    background: #fffcf3;
                    opacity: 1;
                    display: block;
                    position: absolute;
                    top: 0;
                    left: 0;
                    z-index: -1;
                }
            }

            .cs-logo-title {
                font-size: (20/16rem);
                text-transform: initial;
                font-weight: 700;
                margin: 0;
                width: 100%;
                max-width: (100%);
                color: var(--headerColor);
            }

            .cs-logo-wrapper {
                width: 100%;
                display: flex;
                justify-content: center;
                align-items: center;
                flex-wrap: wrap;
                gap: 1.5rem;
                align-self: stretch;
            }

            .cs-logo {
                width: 45%;
                max-width: (200/16rem);
                height: auto;
                margin: 0;
                mix-blend-mode: darken;
                display: block;
            }
        }
    }

    /* Tablet - 768px */
    @media only screen and (min-width: 48rem) {
        #logos-2335 {
            padding-left: (32/16rem);
            position: relative;
            z-index: 100;

            .cs-logo-container {
                align-items: flex-start;

                &:before {
                    width: 100vw;
                    left: 0;
                }
            }

            .cs-logo-wrapper {
                display: grid;
                grid-template-columns: repeat(12, 1fr);
                gap: (64/16rem);
                justify-content: space-between;
            }

            .cs-logo {
                width: 100%;
                grid-column: span 3;
                max-width: max-content;
            }
        }
    }

    /* Large Desktop - 1300px */
    @media only screen and (min-width: 81.25rem) {
        #logos-2335 {
            .cs-logo-wrapper {
                justify-content: space-between;
            }
            .cs-logo-container {
                flex-direction: row;
            }
            .cs-logo-title {
                text-align: left;
            }
        }
    }

    /* Dark Mode */
    @media only screen and (min-width: 0rem) {
        body.dark-mode {
            #logos-2335 {
                .cs-logo-container {
                    &:before {
                        background-color: var(--medium);
                        border: 1px solid rgba(255, 255, 255, 0.2);
                    }
                }
                .cs-logo-title {
                    color: var(--bodyTextColorWhite);
                }
                .cs-logo {
                    filter: grayscale(1) brightness(1000%);
                }
            }
        }
    }
</style>
